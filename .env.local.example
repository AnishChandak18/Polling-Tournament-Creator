# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://shewxkxhmjzgiqmebrns.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_q0EJFoqCVZAHTS-oWqUFsA_oq3e7BJs

# Public site URL (production). Must match Supabase Auth redirect allow list — see below.
# Local dev: omit this (app uses http://localhost:PORT from the browser).
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: http://localhost:3000 (dev) or your production URL
# - Additional Redirect URLs (add each origin you use):
#   http://localhost:3000/auth/callback
#   https://your-production-domain.com/auth/callback
# Optional wildcard (covers ?next= query on callback): http://localhost:3000/**
# Invite links use /join — no Supabase redirect entry needed for /join itself.

# Prisma (Supabase Postgres)
# Prisma CLI only auto-loads `.env`, not `.env.local` — use npm run db:migrate
# DATABASE_URL = pooler :6543 (app). DIRECT_URL = session :5432 (kept for prisma tooling)
# Schema sync: npm run db:migrate  |  displayMeta only: npm run db:add-display-meta
DATABASE_URL=postgresql://postgres.shewxkxhmjzgiqmebrns:<YOUR_DB_PASSWORD>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.shewxkxhmjzgiqmebrns:<YOUR_DB_PASSWORD>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# Optional: server-side Supabase admin (only if needed later)
SUPABASE_SERVICE_ROLE_KEY=

# IPL fixtures provider (pick one)
# Option A: cricapi.com
CRICAPI_API_KEY=4474653e-dc87-43e0-b29c-953d442cc9b6
CRICAPI_SERIES_ID_IPL=
# Optional override for CricAPI base URL
# CRICAPI_BASE_URL=https://api.cricapi.com/v1

# Option B: community fallback (no key)
IPL_FALLBACK_API_BASE=https://ipl-okn0.onrender.com

# Option C: RapidAPI — "Cricbuzz Cricket" (cricbuzz-cricket.p.rapidapi.com)
# Required. Defaults: GET /schedule/v1/league, score GET /mcenter/v1/{matchId}/hscard, commentary /mcenter/v1/{matchId}/hcomm
RAPIDAPI_KEY=
# Optional (defaults shown):
# RAPIDAPI_HOST=https://cricbuzz-cricket.p.rapidapi.com
# RAPIDAPI_SCHEDULE_PATH=/schedule/v1/league
# Or set a full schedule URL instead:
# RAPIDAPI_SCHEDULE_URL=https://cricbuzz-cricket.p.rapidapi.com/schedule/v1/league
# Legacy Free Cricbuzz query-style URLs (set both if you still use that API):
# RAPIDAPI_SCOREBOARD_URL=...
# RAPIDAPI_COMMENTARY_URL=...

