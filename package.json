{
  "name": "polling-tournament-creator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "analyze": "ANALYZE=true prisma generate && next build --webpack",
    "knip": "knip",
    "postinstall": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma db push",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:deploy:prod": "prisma migrate deploy",
    "db:baseline-resolve": "dotenv -e .env.local -- prisma migrate resolve --applied 20260331120000_add_match_display_meta && dotenv -e .env.local -- prisma migrate resolve --applied 20260409120000_user_last_fixture_sync && dotenv -e .env.local -- prisma migrate resolve --applied 20260409130000_invite_and_profile",
    "db:add-display-meta": "dotenv -e .env.local -- prisma db execute --schema prisma/schema.prisma --file prisma/migrations/20260331120000_add_match_display_meta/migration.sql",
    "db:secure": "dotenv -e .env.local -- prisma db execute --schema prisma/schema.prisma --file prisma/sql/rls_policies.sql",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.1.7",
    "prisma": "^6.19.2",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.7",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.4",
    "knip": "^5.88.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "typescript-eslint": "^8.46.0"
  }
}
